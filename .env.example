# ==================== 数据库配置 ====================
# 详见 CLAUDE.md 架构规则 + docs/deployment.md
# PostgreSQL 连接字符串 — 生产必须使用 pooler URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/outreach_hub?schema=public"

# ==================== 认证配置 ====================
# JWT 密钥（生产环境必须更换为随机字符串，至少 32 字符）
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3030"

# ==================== AI 配置 ====================
OPENAI_API_KEY="your-volcengine-ark-api-key"
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_MODEL="doubao-seed-2-0-pro-260215"

# ==================== 平台邮件配置（SMTP）====================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-platform-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_SECURE="false"

# ==================== IMAP 配置（收信，可选）====================
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""

# ==================== 定时任务 / 安全（生产必填）====================
CRON_SECRET="your-cron-secret-change-in-production"
BOUNCE_WEBHOOK_SECRET=""

# ==================== 第三方数据源 ====================
# 联系人搜索（已有）
ROCKETREACH_API_KEY=""
# 联系人搜索 + enrichment（M1: Apollo）
APOLLO_API_KEY=""
# 域名邮箱搜索 + 邮箱验证（M2: Hunter）
HUNTER_API_KEY=""
# 高精度邮箱验证 98.5%（M3: MillionVerifier）
MILLION_VERIFIER_API_KEY=""

# 海关数据（N: Customs Data Prospecting）
CUSTOMS_PROVIDER="importgenius"
CUSTOMS_API_KEY=""
CUSTOMS_API_URL="https://api.importgenius.com"

# ==================== 应用配置 ====================
APP_NAME="OutreachHub"
APP_URL="http://localhost:3030"

# ==================== 加密配置（生产必填）====================
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ==================== Redis（生产邮件队列必填）====================
REDIS_URL="redis://localhost:6379"

# ==================== 文件存储 ====================
# 自动选择后端（见 src/lib/env.ts → getStorageBackend）：
#   有 BLOB_READ_WRITE_TOKEN → Vercel Blob
#   否则 → 本地磁盘 public/uploads/
#
# 【本地开发】留空下方变量，文件写入 public/uploads/（avatars、attachments）
# 【Vercel 生产】Storage 面板创建 Blob Store 并关联项目，平台自动注入 BLOB_READ_WRITE_TOKEN

# Vercel Blob（生产由 Vercel 注入；本地开发保持为空）
BLOB_READ_WRITE_TOKEN=""

# ==================== 公海自动回收 ====================
# 私海联系人超过此天数未跟进自动回收到公海（默认 30，范围 1-365）
POOL_AUTO_RELEASE_DAYS=30

# ==================== Worker 扩展配置（可选）====================
EMAIL_WORKER_CONCURRENCY=5
EMAIL_WORKER_RATE_MAX=100
EMAIL_WORKER_RATE_DURATION_MS=60000
WORKER_HEALTH_PORT=8080
CRON_WORKER_HEALTH_PORT=8082
IMAP_WORKER_HEALTH_PORT=8081

# ==================== Stripe 计费（Batch R）====================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe Price IDs（在 Stripe Dashboard 创建价格后填入）
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# ==================== 部署拓扑 ====================
# Web: Vercel (vercel.json Cron)
# Workers: docker compose up worker cron-worker imap-worker
# 详见 docs/deployment.md
