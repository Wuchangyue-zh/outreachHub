# ==================== 数据库配置 ====================
# 详见 CLAUDE.md 架构规则 + docs/deployment.md
# PostgreSQL 连接字符串 — 生产必须使用 pooler URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/outreach_hub?schema=public"

# ==================== 认证配置 ====================
# JWT 密钥（生产环境必须更换为随机字符串，至少 32 字符）
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3030"

# ==================== AI 配置 ====================
OPENAI_API_KEY="your-volcengine-ark-api-key"
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_MODEL="doubao-seed-2-0-pro-260215"

# ==================== 平台邮件配置（SMTP）====================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-platform-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_SECURE="false"

# ==================== IMAP 配置（收信，可选）====================
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""

# ==================== 定时任务 / 安全（生产必填）====================
CRON_SECRET="your-cron-secret-change-in-production"
BOUNCE_WEBHOOK_SECRET=""

# ==================== 第三方服务 ====================
MILLION_VERIFIER_API_KEY=""
ROCKETREACH_API_KEY=""

# ==================== 应用配置 ====================
APP_NAME="OutreachHub"
APP_URL="http://localhost:3030"

# ==================== 加密配置（生产必填）====================
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ==================== Redis（生产邮件队列必填）====================
REDIS_URL="redis://localhost:6379"

# ==================== 文件存储 ====================
# 优先级：Vercel Blob > S3 兼容 > 本地磁盘

# 方式一：Vercel Blob（推荐，Vercel 部署时自动注入）
BLOB_READ_WRITE_TOKEN=""

# 方式二：S3 兼容存储（Cloudflare R2 / AWS S3 / MinIO）
# 设置以下三个变量后自动启用 S3 存储
S3_ENDPOINT=""              # Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY=""            # S3 Access Key ID
S3_SECRET_KEY=""            # S3 Secret Access Key
S3_BUCKET="outreachhub"     # Bucket 名称
S3_REGION="auto"            # AWS 区域 / Cloudflare R2 用 auto
S3_PUBLIC_URL=""            # 自定义域名，如 https://cdn.example.com
S3_FORCE_PATH_STYLE="false" # MinIO 等需要设为 true

# ==================== Worker 扩展配置（可选）====================
EMAIL_WORKER_CONCURRENCY=5
EMAIL_WORKER_RATE_MAX=100
EMAIL_WORKER_RATE_DURATION_MS=60000
WORKER_HEALTH_PORT=8080
CRON_WORKER_HEALTH_PORT=8082
IMAP_WORKER_HEALTH_PORT=8081

# ==================== 部署拓扑 ====================
# Web: Vercel (vercel.json Cron)
# Workers: docker compose up worker cron-worker imap-worker
# 详见 docs/deployment.md
