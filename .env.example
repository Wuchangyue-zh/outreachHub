# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/outreach_hub?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4o"

# Email Sending (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"

# IMAP (for receiving emails)
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""

# MillionVerifier (email verification)
MILLION_VERIFIER_API_KEY=""

# RocketReach API
ROCKETREACH_API_KEY=""

# App Settings
APP_NAME="OutreachHub"
APP_URL="http://localhost:3000"
