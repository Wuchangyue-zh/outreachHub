# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接字符串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/outreach_hub?schema=public"

# ==================== 认证配置 ====================
# NextAuth 密钥（生产环境必须更换为随机字符串）
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ==================== AI 配置 ====================
# OpenAI / 火山方舟（豆包）— OpenAI 兼容 API
# 文档: https://www.volcengine.com/docs/82379/1399008?lang=zh
OPENAI_API_KEY="your-volcengine-ark-api-key"
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_MODEL="doubao-seed-2-0-pro-260215"

# ==================== 平台邮件配置（SMTP）====================
# 用于系统邮件：注册欢迎邮件、密码重置、通知等
# 这是平台默认的发件账户，用户未配置自己的 EmailAccount 时使用
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-platform-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_SECURE="false"

# ==================== 用户邮件账户（EmailAccount）====================
# 用户可以在 Settings 页面配置自己的 SMTP 账户
# 用于：Campaign 发送、测试邮件、Inbox 回复等
# 配置存储在数据库的 EmailAccount 表中（密码已加密）
# 用户 SMTP 配置优先级高于平台 SMTP

# ==================== IMAP 配置（收信）====================
# 用于接收回复邮件（可选）
# 如果用户配置了 EmailAccount 的 IMAP，优先使用用户的 IMAP
# 这里配置的是平台默认的 IMAP（用于向后兼容）
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""

# ==================== 定时任务配置 ====================
# Cron 任务密钥（可选，用于验证请求来源）
# 建议在生产环境设置，防止未授权访问
CRON_SECRET=""

# Vercel Cron 配置（已在 vercel.json 中配置）
# - check-replies: 每 5 分钟检查回复邮件
# - launch-scheduled: 每 1 分钟检查定时 Campaign

# ==================== 第三方服务 ====================
# MillionVerifier（邮箱验证服务）
MILLION_VERIFIER_API_KEY=""

# RocketReach（拓客 API）
ROCKETREACH_API_KEY=""

# ==================== 应用配置 ====================
APP_NAME="OutreachHub"
APP_URL="http://localhost:3000"

# ==================== 数据库配置（本地开发）====================
# 如果使用 Docker，端口可能是 5433
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/outreach_hub?schema=public"

# ==================== 加密配置 ====================
# 用于加密 EmailAccount 的 SMTP/IMAP 密码
# 生产环境必须设置此变量（32 字节 hex 字符串或任意字符串）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ==================== Redis 配置（可选）====================
# 用于 BullMQ 邮件队列
# 如果未配置，邮件将直接发送（无队列）
REDIS_URL="redis://localhost:6379"
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
